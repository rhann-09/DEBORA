FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties.water;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
	// Esto tenia seteado yo en el experimento
    RASModel  	kOmegaSST;

    turbulence      on;
    printCoeffs     on;
}


