FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties.liquid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Setup: Matches https://doi.org/10.3390/en16134996 Tables 3 and 4, suggests hRefConst

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hRefConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleInternalEnergy;
}

mixture
{
    specie
    {
        molWeight       120.93;  // g/mol
    }
    equationOfState
    {
        rho        1016.4;  // kg/m^3
    }
    thermodynamics
    {
        Hf          0;
        Cp          1357.5;  // https://doi.org/10.3390/en16134996  J/(kg*K)
        Tref        358;  // https://www.engineeringtoolbox.com/dichlorodifluoromethane-R-12-d_972.html K
        Href        125930;  // https://www.engineeringtoolbox.com/dichlorodifluoromethane-R-12-d_972.html J/kg
    }
    transport
    {
        mu          8.9402e-05;  //  dynamic viscosity Pa*s https://webbook.nist.gov/cgi/cbook.cgi?ID=C75718&Mask=1F
        Pr          2.638;   // Prandtl number Pr=cp*mu/k, k = 0.046 
    }
}



