FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type            thermalPhaseChangeTwoPhaseSystem;

phases          (gas liquid);

phaseChange on;

gas
{
    type            purePhaseModel;
    diameterModel   constant;
    constantCoeffs
    {
        d                0.0003; 
    }
    Sc              0.7;

    residualAlpha   1e-4;
}

liquid
{
    type            purePhaseModel;
    diameterModel   constant;
    constantCoeffs
    {
        d               0.0006; 
    }
    Sc              0.7;

    residualAlpha   1e-4;
}

blending
{
    default
    {
        type            none;
        continuousPhase liquid;
    }
}

surfaceTension
(
    (gas and liquid)
    {
        type            constant;
        sigma           0.038; 
    }

    (liquid and gas)
    {
        type            constant;
        sigma           0.038; 
    }
);

saturationModel
{
        type constant;

        Tsat 530.65;
        pSat 4.5e6;
};

aspectRatio
(

    (gas in liquid)
    {
        type            constant;
        E0              0.01777207997368;
    }

    (liquid in gas)
    {
        type            constant;
        E0               0.07108831989474; 
    }
);





drag
(
 	(gas in liquid)
    {
        type            Grace; 
	A		16;
        residualAlpha   1e-6;
        residualRe      1e-6;
	muref1          0.0009;
	gref		9.81;		        
	swarmCorrection
        {
            type        none;
        }
    }

    (liquid in gas)
    {
      	type            TomiyamaCorrelated; 
	A		16;        
	residualRe      1e-3;
	residualAlpha   1e-3;        
        swarmCorrection
        {
            type        none;
        }
    }

    (gas and liquid)
    {
        type            segregated;
        m               0.5;
        n               8;
        swarmCorrection
        {
            type        none;
        }
    }


);

virtualMass
(
    
    (gas in liquid)
    {
        type            constantCoefficient;
        Cvm             0.5;
    }

    (liquid in gas)
    {
        type            constantCoefficient;
        Cvm             0.5;
    }
);

heatTransfer.gas
(
    (gas in liquid)
    {
	type            RanzMarshall;		
        residualAlpha   1e-3;        
    }

    (liquid in gas)
    {
	type            RanzMarshall; 
        residualAlpha   1e-3;        
    }

);

heatTransfer.liquid
(
    (gas in liquid)
    {
	type            RanzMarshall; 		
        residualAlpha   1e-3;        
    }

    (liquid in gas)
    {
	type            RanzMarshall;
        residualAlpha   1e-3;        
    }

);

phaseTransfer
();

lift
(
	(gas in liquid)
    {
     	type            Tomiyama; 
    }

  	(liquid in gas)
    {
     	type            Tomiyama; 
    }
);

wallLubrication
(
	(gas in liquid)
    {
     	type            Frank; 
        Cwd             6.8;
	Cwc		10; 
    	p		1.7;		
    
    }
	(liquid in gas)
    {
     	type            Frank;
        Cwd             6.8; 
	Cwc		10;
    	p		1.7;
    }
);

turbulentDispersion
(
     (gas in liquid)
     {
        type                Burns; 
        sigma               0.7; 
        Ctd                 1; 
        residualAlpha       1e-4 ; 
    }

	(liquid in gas)
    {
     	type                Burns; 
        sigma               0.9;
        Ctd                 0.5;
        residualAlpha       1e-4;
    
    }

);

// Minimum allowable pressure
pMin            10000;
