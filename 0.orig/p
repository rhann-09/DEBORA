FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform 2620000;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 2620000;
    }
    outlet
    {
        type            calculated;
        value           uniform 2620000;
    }
    unheated_wall
    {
        type            calculated;
        value           uniform 2620000;
    }
    heated_wall
    {
        type            calculated;
        value           uniform 2620000;
    }
    axis
    {
        type            empty;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
}
