FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T.liquid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// temperature
// Matches https://doi.org/10.3390/en16134996 Table 4. using inlet temperature

dimensions      [0 0 0 1 0 0 0];
internalField   uniform 341.67;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 341.67;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 341.67;
        value           uniform 341.67;
    }
    unheated_wall
    {
        type            zeroGradient;
    }
    heated_wall
    {
		// Matches https://doi.org/10.3390/en16134996 Table 4. DEBORA 1
        type            fixedMultiPhaseHeatFlux; 
        // q               uniform 73890;  // vapour development
		q               uniform 0;   // flow field development
        value           uniform 341.67;
    }
    axis
    {
        type            empty;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
}
