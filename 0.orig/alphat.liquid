FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alphat.liquid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// alphat: turbulent thermal diffusivity

dimensions      [1 -1 -1 0 0 0 0];
internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            calculated;  // Matches https://doi.org/10.3390/en16134996 Table 4.
        value           uniform 0;   // Ref: Material_PaperCHT close to 0
    }
    outlet
    {
        type            calculated;  // Matches https://doi.org/10.3390/en16134996 Table 4.
        value           uniform 0;   // Ref: Material_PaperCHT close to 0
    }
    unheated_wall
    {
        type            compressible::alphatWallFunction; // Matches https://doi.org/10.3390/en16134996 Table 4.
		kName           k.liquid;
        nutName         nut.liquid;
        UName           U.liquid;
        Prt             0.85;        //	Turbulent Prandtl number, typ. 0.85 
        value           uniform 0;   // Ref: Material_PaperCHT close to 0
    }
    heated_wall
    {
        type            compressible::alphatWallBoilingWallFunction;  // Matches https://doi.org/10.3390/en16134996 Table 4.
        phaseType       liquid;
		kName           k.liquid;
        nutName         nut.liquid;
        UName           U.liquid;
		otherPhase      gas;
        Prt             0.85;        //	Turbulent Prandtl number, typ. 0.85 
        relax           0.01;        // relaxation factor
        value           uniform 0;   // Ref: Material_PaperCHT close to 0

        partitioningModel
        {
            type        phaseFraction;
        }

        // DEBORA 1 Tuned sub-models (Table 6)
        nucleationSiteModel
        {
            type        LemmertChawla;  // Matches https://doi.org/10.3390/en16134996 Table 6 DEBORA 1
            Cn          1.60;           // Matches https://doi.org/10.3390/en16134996 Table 6 DEBORA 1
            Nref        25e6;           // Matches https://doi.org/10.3390/en16134996 Table 6 DEBORA 1
            deltaTref   10;             // Matches https://doi.org/10.3390/en16134996 Table 6 DEBORA 1
        }

        departureDiamModel
        {
            type        TolubinskiKostanchuk;  // Matches https://doi.org/10.3390/en16134996 Table 6 DEBORA 1
            dRef        0.00048;               // Matches https://doi.org/10.3390/en16134996 Table 6 DEBORA 
        }

        departureFreqModel
        {
            type        Cole;          // Ref: Material_PaperCHT & only Cole available
        }
        value           uniform 0.01;  // Ref: Material_PaperCHT

    }
    axis
    {
        type            empty;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
}
